{
  "name": "money-trail",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },
  "remoteUser": "vscode",
  "init": true,
  "overrideCommand": true,
  "command": "/bin/sh",
  "args": ["-c", "while sleep 1000; do :; done"],
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "forwardPorts": [8080, 5432],
  "portsAttributes": {
    "8080": {
      "label": "Airflow Webserver"
    },
    "5432": {
      "label": "PostgreSQL"
    }
  },
  "containerEnv": {
    "AIRFLOW_HOME": "/workspaces/money-trail/.airflow",
    "AIRFLOW__CORE__LOAD_EXAMPLES": "False",
    "AIRFLOW__CORE__EXECUTOR": "SequentialExecutor",
    "AIRFLOW__DATABASE__SQL_ALCHEMY_CONN": "postgresql://airflow:[REDACTED]@localhost:5432/airflow",
    "AIRFLOW__WEBSERVER__EXPOSE_CONFIG": "True",
    "OPENLINEAGE_URL": "http://localhost:5000",
    "OPENLINEAGE_NAMESPACE": "money-trail-dev",
    "DBT_PROFILES_DIR": "/workspaces/money-trail/dbt"
  },
  "remoteEnv": {
    "WORKDIR": "/workspaces/money-trail",
    "OPENLINEAGE_NAMESPACE": "money-trail-dev",
    "DBT_PROFILES_DIR": "/workspaces/money-trail/dbt"
  },
  "services": {
    "postgres": {
      "image": "postgres:16.3-alpine",
      "environment": {
        "POSTGRES_DB": "airflow",
        "POSTGRES_USER": "airflow",
        "POSTGRES_PASSWORD": "airflow"
      },
      "ports": ["5432:5432"],
      "volumes": ["postgres-data:/var/lib/postgresql/data"],
      "healthCheck": {
        "test": ["CMD-SHELL", "pg_isready -U airflow -d airflow"],
        "interval": 2,
        "timeout": 5,
        "retries": 5,
        "startPeriod": 5
      }
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "dev.containers.mountWaylandSocket": false,
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.analysis.typeCheckingMode": "basic",
        "python.linting.enabled": true,
        "python.linting.pylintEnabled": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true
        },
        "[dbt]": {
          "editor.formatOnSave": true
        },
        "dbt.parseOnSave": true,
        "dbt.formatOnSave": true,
        "editor.formatOnSave": true,
        "files.trimTrailingWhitespace": true
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-docker",
        "innoverio.vscode-dbt-power-user",
        "charliermarsh.ruff",
        "redhat.vscode-yaml",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-postgres",
        "GitHub.copilot",
        "GitHub.copilot-chat"
      ]
    }
  },
  "postCreateCommand": "bash scripts/init_fernet_key.sh && bash scripts/bootstrap.sh 2>&1 | tail -50 || echo 'Bootstrap completed with warnings'",
  "postStartCommand": "bash scripts/start_airflow.sh 2>&1 | grep -E '(ERROR|WARNING|READY|Listening)' || echo 'Airflow services started'",
  "mounts": [
    "source=money-trail-pip-cache,target=/home/vscode/.cache/pip,type=volume",
    "source=money-trail-build-cache,target=/home/vscode/.cache/docker,type=volume"
  ],
  "volumes": {
    "postgres-data": {},
    "money-trail-build-cache": {}
  }
}
