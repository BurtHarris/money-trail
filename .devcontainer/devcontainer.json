{
  "name": "money-trail",
  "dockerComposeFile": "docker-compose.yml",
  "service": "devcontainer",
  "runServices": ["postgres"],
  "workspaceFolder": "/workspaces/money-trail",
  "remoteUser": "vscode",
  "init": true,
  "containerEnv": {
    "COMPOSE_PROGRESS": "plain",
    "AIRFLOW_HOME": "/workspaces/money-trail/.airflow",
    "AIRFLOW__CORE__LOAD_EXAMPLES": "False",
    "AIRFLOW__CORE__EXECUTOR": "LocalExecutor",
    "AIRFLOW__CORE__SQL_ALCHEMY_CONN": "postgresql://airflow:[REDACTED]@postgres:5432/airflow",
    "AIRFLOW__DATABASE__SQL_ALCHEMY_CONN": "postgresql://airflow:[REDACTED]@postgres:5432/airflow",
    "POSTGRES_HOST": "postgres",
    "POSTGRES_PORT": "5432",
    "POSTGRES_DB": "airflow",
    "POSTGRES_USER": "airflow",
    "POSTGRES_PASSWORD": "airflow",
    "AIRFLOW__WEBSERVER__EXPOSE_CONFIG": "True",
    "AIRFLOW__CORE__PARALLELISM": "32",
    "AIRFLOW__CORE__MAX_ACTIVE_TASKS_PER_DAG": "16",
    "AIRFLOW__CORE__DAG_CONCURRENCY": "16",
    "OPENLINEAGE_URL": "http://localhost:5000",
    "OPENLINEAGE_NAMESPACE": "money-trail-dev",
    "DBT_PROFILES_DIR": "/workspaces/money-trail/dbt"
  },
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "forwardPorts": [8080, 5432],
  "portsAttributes": {
    "8080": {
      "label": "Airflow Webserver"
    },
    "5432": {
      "label": "PostgreSQL"
    }
  },
  "remoteEnv": {
    "WORKDIR": "/workspaces/money-trail",
    "OPENLINEAGE_NAMESPACE": "money-trail-dev",
    "DBT_PROFILES_DIR": "/workspaces/money-trail/dbt",
    "COMPOSE_PROGRESS": "plain"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "dev.containers.mountWaylandSocket": false,
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.analysis.typeCheckingMode": "basic",
        "python.linting.enabled": true,
        "python.linting.pylintEnabled": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true
        },
        "[dbt]": {
          "editor.formatOnSave": true
        },
        "dbt.parseOnSave": true,
        "dbt.formatOnSave": true,
        "editor.formatOnSave": true,
        "files.trimTrailingWhitespace": true
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-docker",
        "innoverio.vscode-dbt-power-user",
        "charliermarsh.ruff",
        "redhat.vscode-yaml",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-postgres",
        "GitHub.copilot",
        "GitHub.copilot-chat"
      ]
    }
  },
  "postCreateCommand": "bash scripts/init_fernet_key.sh",

  "mounts": [
    "source=money-trail-pip-cache,target=/home/vscode/.cache/pip,type=volume",
    "source=money-trail-build-cache,target=/home/vscode/.cache/docker,type=volume"
  ]
}
