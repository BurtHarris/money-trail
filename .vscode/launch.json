{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Daily: F5 Smart UI",
      "type": "node-terminal",
      "request": "launch",
      "command": "bash scripts/runtime_f5.sh",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "Docker: Ensure Running"
    },
    {
      "name": "Daily: Watch Runtime Logs",
      "type": "node-terminal",
      "request": "launch",
      "command": "bash scripts/runtime.sh logs -f",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Daily: Run All Tests",
      "type": "node-terminal",
      "request": "launch",
      "command": "if [ -f /.dockerenv ] || [ -n \"${REMOTE_CONTAINERS:-}\" ] || [ -n \"${DEVCONTAINER:-}\" ]; then bash scripts/run-tests.sh; else bash scripts/run-tests.sh --local; fi",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Advanced: Runtime Up",
      "type": "node-terminal",
      "request": "launch",
      "command": "bash scripts/runtime.sh up",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "Docker: Ensure Running"
    },
    {
      "name": "Advanced: Runtime Down",
      "type": "node-terminal",
      "request": "launch",
      "command": "bash scripts/runtime.sh down",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Advanced: Debug Current Python File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${command:python.interpreterPath}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "justMyCode": false
    },
    {
      "name": "Advanced: Debug Tests (workspace)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "-q",
        "tests"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${command:python.interpreterPath}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "justMyCode": false
    },
    {
      "name": "Advanced: Debug Tests (current file)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "-q",
        "${file}"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${command:python.interpreterPath}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "justMyCode": false
    }
  ]
}
